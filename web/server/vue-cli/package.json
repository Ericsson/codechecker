{
  "name": "codechecker",
  "version": "1.0.0",
  "description": "CodeChecker viewer.",
  "author": "Márton Csordás",
  "private": true,
  "scripts": {
    "build": "rimraf dist && cross-env NODE_ENV=production webpack --config config/webpack.prod.js",
    "server:codechecker": "CodeChecker server --port 8002 -w e2e/__codechecker/workspace > e2e/__codechecker/server.log",
    "server:dev": "cross-env NODE_ENV=development webpack server --hot --progress --config config/webpack.dev.js",
    "server:prod": "http-server dist -c-1 --cors",
    "server": "npm run server:dev",
    "start": "npm run server",
    "test:clean": "npm run test:e2e.clean",
    "test:e2e": "npm run test:e2e.firefox && npm run test:e2e.chrome",
    "test:e2e.clean": "rimraf e2e/output e2e/screenshots e2e/__codechecker/workspace e2e/__codechecker/reports e2e/__codechecker/compilation_database",
    "test:e2e.chrome": "server-test test:e2e.server http-get://localhost:8002/ready 'npm run test:e2e.init-db && npm run test:nightwatch -- -e chrome'",
    "test:e2e.firefox": "server-test test:e2e.server http-get://localhost:8002/ready 'npm run test:e2e.init-db && npm run test:nightwatch -- -e firefox'",
    "test:e2e.init-db": "node e2e/init.db.js",
    "test:e2e.init-reports": "node e2e/init.reports.js",
    "test:e2e.init-workspace": "node e2e/init.workspace.js",
    "test:e2e.server": "npm run test:e2e.init-reports && rimraf e2e/__codechecker/workspace && npm run test:e2e.init-workspace && npm run server:codechecker",
    "test:lint": "eslint --ext .js,.vue src",
    "test:nightwatch": "nightwatch",
    "test:unit": "jest",
    "test": "npm run test:lint && npm run test:unit && npm run test:e2e"
  },
  "dependencies": {
    "@codemirror/lang-cpp": "^6.0.3",
    "@codemirror/lang-go": "^6.0.1",
    "@codemirror/lang-java": "^6.0.2",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-python": "^6.2.1",
    "@mdi/font": "^6.9.96",
    "chart.js": "^4.5.1",
    "chartjs-plugin-datalabels": "^2.2.0",
    "codechecker-api": "file:../../api/js/codechecker-api-node/dist/codechecker-api-6.72.0.tgz",
    "codemirror": "^6.0.2",
    "date-fns": "^2.30.0",
    "dompurify": "^3.4.12",
    "js-cookie": "^3.0.8",
    "jsplumb": "^2.15.6",
    "lodash": "^4.18.1",
    "marked": "^4.3.0",
    "mitt": "^3.0.1",
    "semver": "^5.7.2",
    "splitpanes": "^4.1.2",
    "uuid": "^13.0.2",
    "vue": "3.5.25",
    "vue-chartjs": "^5.3.3",
    "vue-codemirror": "^6.1.1",
    "vue-loader": "^17.4.2",
    "vue-router": "^4.6.4",
    "vuetify": "^3.12.8",
    "vuex": "4.1.0",
    "webpack-plugin-vuetify": "^3.1.3"
  },
  "devDependencies": {
    "@babel/cli": "^7.29.7",
    "@babel/core": "^7.29.7",
    "@babel/preset-env": "^7.29.7",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9.39.2",
    "@types/jest": "^27.5.2",
    "@vue/compiler-sfc": "3.5.25",
    "@vue/test-utils": "2.0.0",
    "@vue/vue3-jest": "^28.1.0",
    "babel-core": "^7.0.0-bridge.0",
    "babel-eslint": "^10.1.0",
    "babel-jest": "^28.1.3",
    "babel-loader": "^8.4.1",
    "buffer": "^6.0.3",
    "copy-webpack-plugin": "^14.0.0",
    "core-js": "^3.49.0",
    "cross-env": "^7.0.3",
    "css-loader": "^6.11.0",
    "deepmerge": "^4.3.1",
    "eslint": "^9.39.4",
    "eslint-plugin-vue": "^10.9.2",
    "eslint-webpack-plugin": "^5.0.3",
    "file-loader": "^6.2.0",
    "geckodriver": "^6.1.0",
    "globals": "^17.7.0",
    "html-webpack-plugin": "^5.6.7",
    "http-server": "^14.1.1",
    "jest": "^28.1.3",
    "nightwatch": "^3.16.0",
    "raw-loader": "^4.0.2",
    "regenerator-runtime": "^0.13.11",
    "rimraf": "^3.0.2",
    "sass": "^1.101.0",
    "sass-loader": "^16.0.8",
    "selenium-server": "^3.141.59",
    "start-server-and-test": "^2.1.5",
    "util": "^0.12.5",
    "vue-eslint-parser": "^10.4.1",
    "vue-style-loader": "^4.1.3",
    "webpack": "^5.108.3",
    "webpack-cli": "^7.1.0",
    "webpack-dev-server": "^5.2.5",
    "webpack-merge": "^5.10.0"
  },
  "overrides": {
    "serialize-javascript": "^7.0.5",
    "js-yaml": "^4.1.2",
    "nightwatch": {
      "uuid": "^11.1.1"
    },
    "sockjs": {
      "uuid": "^11.1.1"
    }
  },
  "engines": {
    "node": ">=14.17.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "vue"
    ],
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/src/$1",
      "@cc/report-server-types": "codechecker-api/lib/report_server_types.js",
      "@cc/prod-types": "codechecker-api/lib/products_types.js"
    },
    "transform": {
      ".*\\.(vue)$": "@vue/vue3-jest",
      "^.+\\.js$": "babel-jest"
    }
  }
}
